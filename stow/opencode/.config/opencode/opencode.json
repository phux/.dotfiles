{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "small_model": "google/gemini-3-flash-preview",
  "default_agent": "planner",
  "agent": {
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring. Use for implementation planning, architectural changes, or complex refactoring.",
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "prompt": "{file:~/.config/opencode/prompts/agents/planner.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan for complex features",
      "template": "{file:~/.config/opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    }
  }
}
