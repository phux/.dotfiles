{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "small_model": "google/gemini-3-flash-preview",
  "autoupdate": true,
  "mcp": {
    "code-search-mcp": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/home/jm/code/code-search-mcp",
        "run",
        "code-search-mcp"
      ]
    },
    "atlassian-mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/home/jm/code/atlassian-mcp",
        "atlassian-mcp"
      ]
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "*.lock"
    ]
  },
  "instructions": [
    "CONTRIBUTING.md",
    "docs/specs/INDEX.md",
    "AGENTS.md"
  ],
  "command": {
    "ticket-validator": {
      "description": "Grade ticket or PRD quality against project specs",
      "template": "{file:~/.config/opencode/commands/ticket-validator.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    }
  }
}
