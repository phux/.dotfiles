{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "autoupdate": true,
  "small_model": "google/gemini-3-flash-preview",
  "default_agent": "planner",
  "agent": {
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring. Use for generating PRD from initial user queries",
      "mode": "subagent",
      "model": "google/gemini-3.1-pro-preview",
      "prompt": "{file:~/.config/opencode/skills/product-manager/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "Expert architect. Use for generating Technical Specification Documents from PRDs generated by the planner",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:~/.config/opencode/skills/architect/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "implementer": {
      "description": "Expert coder. Use for implementing Technical Specification Documents generated by the architect",
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "prompt": "{file:~/.config/opencode/skills/implementer/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "reviewer": {
      "description": "Expert code reviewer. Use for reviewing changes done by the implementer",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:~/.config/opencode/skills/code-reviewer/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "qa-engineer": {
      "description": "Expert qa engineer. Use for generating test suites for the results of the implementer",
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "prompt": "{file:~/.config/opencode/skills/qa-engineer/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "debugger": {
      "description": "Expert debugger. Trigger when test execution fails, stack traces are provided, or runtime errors occur.",
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "prompt": "{file:~/.config/opencode/skills/debugger/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "documenter": {
      "description": "Expert documenter. Use for generating documentation for the results of the PRD, TDD, and implementer",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:~/.config/opencode/skills/documenter/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan for complex features",
      "template": "{file:~/.config/opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    }
  }
}
